{
  "name": "webapp",
  "version": "1.0.0",
  "scripts": {
    "init": "cd front && npm i && cd ../cdk && npm i",
    "front:start": "cd front && ng serve",
    "front:build": "cd front && ng build --configuration production",
    "cdk:synth": "cd cdk && cdk synth",
    "cdk:deploy": "cd cdk && cdk deploy --require-approval never",
    "deploy": "npm run front:build && npm run cdk:deploy",
    "destroy": "cd cdk && cdk destroy"
  }
}

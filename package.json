{
  "name": "webapp",
  "version": "1.0.0",
  "scripts": {
    "init": "cd front && npm i && cd ../cdk && npm i",
    "front:start": "cd front && npm run start",
    "front:start:production": "cd front && npm run front:start:production",
    "front:build": "cd front && npm run build",
    "cdk:synth": "cd cdk && npm run synth",
    "cdk:deploy": "cd cdk && npm run deploy",
    "deploy": "npm run front:build && npm run cdk:deploy",
    "destroy": "cd cdk && npm run destroy"
  }
}
